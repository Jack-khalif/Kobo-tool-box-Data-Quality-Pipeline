    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "np.random.seed(42)  # reproducible\n",
    "\n",
    "n = 50\n",
    "dates = pd.date_range(start='2025-01-01', periods=n, freq='D')\n",
    "\n",
    "data = {\n",
    "    'Farmer_ID': [f'FARMER_{i:04d}' for i in range(1, n+1)],\n",
    "    'Region': np.random.choice(['East', 'North', 'South', 'West'], n),\n",
    "    'Crop_Type': np.random.choice(['Maize', 'Rice', 'Soybean', 'Wheat'], n),\n",
    "    'Planting_Date': dates,\n",
    "    'Harvest_Date': dates + pd.to_timedelta(np.random.randint(90, 150, n), unit='D'),\n",
    "    'Yield_kg_per_ha': np.round(np.random.uniform(1000, 9999, n), 2),\n",
    "    'Rainfall_mm': np.round(np.random.uniform(50, 300, n), 1),\n",
    "    'Irrigation_Effectiveness': np.random.choice(['Good', 'Average', 'Poor'], n, p=[0.4, 0.4, 0.2]),\n",
    "    'Pest_Outbreak': np.random.choice(['Yes', 'No'], n, p=[0.3, 0.7]),\n",
    "    'Field_Photo': ['photo_simulated.jpg'] * n,\n",
    "    'Comments': np.random.choice(['Looks healthy', 'Some wilting', 'Heavy rain damage', '', 'Pests spotted'], n)\n",
    "}\n",
    "\n"
   ]
  },
